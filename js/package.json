{
  "name": "@noctusoft/ezodata-express",
  "version": "1.0.4",
  "description": "Bolt a governed OData v4 + REST + MCP API onto any Express app. Pure TypeScript, full parity with the ez-odata .NET engine.",
  "license": "Apache-2.0",
  "author": "Noctusoft, Inc.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "check": "pnpm typecheck && pnpm lint && pnpm depcruise && pnpm test"
  },
  "keywords": [
    "odata",
    "rest",
    "mcp",
    "express",
    "api",
    "rbac",
    "sql"
  ],
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testcontainers/mssqlserver": "^12.0.2",
    "@testcontainers/mysql": "^12.0.2",
    "@testcontainers/postgresql": "^12.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "dependency-cruiser": "^16.8.0",
    "eslint": "^9.17.0",
    "express": "^5.2.1",
    "js-yaml": "^4.2.0",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "mssql": "^12.5.5",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0"
  }
}
